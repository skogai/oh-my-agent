{
  "$schema": "./hook-variant.schema.json",
  "vendor": "cursor",
  "hookDir": ".cursor/hooks",
  "settingsFile": ".cursor/hooks.json",
  "projectDirEnv": null,
  "runtime": "bun",
  "flatHookEntries": true,
  "events": {
    "beforeSubmitPrompt": [
      {
        "hook": "keyword-detector.ts",
        "timeout": 5
      },
      {
        "hook": "state-boundary.ts",
        "timeout": 5
      },
      {
        "hook": "skill-injector.ts",
        "timeout": 3
      },
      {
        "hook": "serena-primer.ts",
        "timeout": 3
      }
    ]
  },
  "extra": {
    "version": 1
  }
}
