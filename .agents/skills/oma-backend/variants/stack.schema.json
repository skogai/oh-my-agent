{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Backend Stack Manifest",
  "description": "Per-variant stack declaration and verify contract consumed by `oma verify backend` and agent structured lookup.",
  "type": "object",
  "required": ["language"],
  "properties": {
    "$schema": { "type": "string" },
    "language": {
      "type": "string",
      "enum": ["python", "node", "rust"],
      "description": "Primary implementation language of the variant."
    },
    "framework": {
      "type": "string",
      "description": "Primary web framework (e.g., fastapi, hono, axum)."
    },
    "orm": {
      "type": "string",
      "description": "Primary ORM/query layer (e.g., sqlalchemy, prisma, sqlx)."
    },
    "source": {
      "type": "string",
      "enum": ["variant", "migrated", "user", "detected"],
      "description": "Origin marker. `variant` = shipped with repo, `migrated` = produced by legacy migration, `user` = hand-customized, `detected` = generated by the stack-set workflow from codebase detection."
    },
    "verify": {
      "type": "object",
      "description": "Executable contract consumed by cli/commands/verify/verify.ts.",
      "properties": {
        "detect": {
          "type": "string",
          "description": "Relative path whose existence in the workspace selects this variant (e.g., package.json)."
        },
        "syntax": {
          "$ref": "../../_shared/core/stack-verify.schema.json#/definitions/commandCheck"
        },
        "tests": {
          "$ref": "../../_shared/core/stack-verify.schema.json#/definitions/commandCheck"
        },
        "raw_sql": {
          "type": "object",
          "description": "Raw-SQL injection grep scan.",
          "required": ["patterns"],
          "properties": {
            "patterns": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1,
              "description": "ERE patterns passed to `grep -E`."
            },
            "include_glob": {
              "type": "string",
              "description": "File pattern for `grep --include`."
            },
            "exclude_dirs": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Directory names to exclude via `grep -v`."
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true,
  "definitions": {
    "commandCheck": {
      "$ref": "../../_shared/core/stack-verify.schema.json#/definitions/commandCheck"
    }
  }
}
