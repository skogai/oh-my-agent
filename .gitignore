# Dependencies
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# Build outputs
dist/
build/
*.js.map
bin/*.js
/cli/bin/
!scripts/dashboard-web/**/*.js
!scripts/generate-manifest.js

# Environment
.env
.env.local
.env.*.local

# OMA outputs
.agents/plan.json
docs/plans/
# oma-docs runtime artifacts (regenerated by `oma docs verify`).
# doc-refs.json is the canonical doc-ref index; tracking it could be
# enabled later once dogfooding stabilizes its diff cadence.
# url-drift.json is lychee output and is always transient.
docs/generated/

# Claude/Codex/Qwen integration layer (generated)
.claude/
.codex/
.qwen/
.kiro/

# pi (Earendil pi-coding-agent) extension bridge (generated)
.pi/

# Cursor/Gemini integration layer (generated)
.cursor/*
.gemini/*

# Antigravity CLI (agy) — local config symlink to Gemini project store
.antigravitycli/

# Grok integration layer (generated by oma link)
.grok/

# Copilot workflow prompt wrappers (generated by `oma link`)
.github/prompts/

# Serena Memory (runtime state)
.serena/memories/*
!.serena/memories/.gitkeep
.serena/metrics.json

# Serena runtime (nested workspaces)
cli/.serena/
web/.serena/

# OMA runtime state (hook persistent mode)
.agents/state/
.agents/results/

# agy (Antigravity) hooks manifest — generated per-install with absolute paths
.agents/hooks.json

# Grok session-start context mirror — generated by the state hooks
.grok/rules/oma-state.md

# Nested oma artifacts (when build/tests run from cli/ with OMA_HOME unset
# they may write a stray .agents/ under cli/ — never tracked)
cli/.agents/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing
coverage/
.nyc_output/
test-results/

# Temporary files
*.tmp
*.temp
.cache/

# OS
Thumbs.db

# Python
__pycache__/
*.pyc

.opencode/mimic/
.mimic/
.omc/

# deepsec workspace (vuln scanner: config, INFO.md, data/, findings/, .env.local)
.deepsec/

# oh-my-agent runtime (local artifacts — do not commit)
.agents/backup/
.migration-backup/
